@model OnpeWeb.Models.ActaUbigeoViewModel
@{
    ViewData["Title"] = "Actas por Ubigeo";
    bool esPeru = Model.AmbitoSeleccionado == "P";
    bool mostrarListadoMesas = !string.IsNullOrEmpty(Model.LocalSeleccionado);
    bool mostrarDetalleActa = !string.IsNullOrEmpty(Model.MesaSeleccionada) && Model.ActaDetalle?.Existe == true;

    var currentAmbito = Model.AmbitoSeleccionado ?? "P";
    var currentDepa = Model.DepartamentoSeleccionado ?? "";
    var currentProv = Model.ProvinciaSeleccionado ?? "";
    var currentDist = Model.DistritoSeleccionado ?? "";
    var currentLocal = Model.LocalSeleccionado ?? "";
    var currentMesa = Model.MesaSeleccionada ?? "";
}

<div class="container">
    <img src="~/images/f-actas.jpg" width="1170" height="248" class="img-responsive mg30top">

        <section class="menu navbar-default menu05">
            <nav class="navbar-collapse bs-navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    <li class="bt-azul"><a href="#">PRESIDENCIAL</a></li>
                    <li class="bt-amarillo act-amarillo"><a href="@Url.Action("ActasUbigeo")">ACTAS</a></li>
                    <li class="bt-rojo"><a href="@Url.Action("Participacion")">PARTICIPACIÓN CIUDADANA</a></li>
                </ul>
            </nav>
        </section>

        <br /><br /><br /><br />

        <section class="contenedor">
            <div class="row">
                <div class="col-xs-12 col-md-3">
                    <div class="menu-interna">
                        <ul>
                            <li><a href="@Url.Action("ActasUbigeo")" class="act-izq">Actas por ubigeo</a></li>
                            <li><a href="@Url.Action("ActasNumero")">Actas por número</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-xs-12 col-md-9" id="impreso">
                    <div class="contenido-interna">
                        <div class="titulos col-xs-12">
                            <div class="col-xs-11">
                                <h3>
                                    <span class="glyphicon glyphicon-circle-arrow-right" aria-hidden="true" style="font-size:19px"></span>
                                    SEGUNDA ELECCIÓN PRESIDENCIAL 2016: ACTAS POR UBIGEO
                                </h3>
                            </div>
                            <div class="col-xs-1 oculto-boton-print">
                                <button onclick="window.print();"><i class="fa fa-print ico-print"></i></button>
                            </div>
                        </div>

                        <div class="col-lg-7 centered">
                            <div class="col-xs-12 col-md-12 col-lg-12 cont-curv">
                                <div class="col-xs-3 col-md-1">
                                    <span class="glyphicon glyphicon-ok-circle ico-info" aria-hidden="true"></span>
                                </div>
                                <div class="col-xs-9 col-md-11">
                                    <ul>
                                        <li>ACTUALIZADO EL 20/06/2016 A LAS 19:16 h</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <br /><br /><br /><br />

                        <form asp-action="ActasUbigeo" method="get">
                            <div class="row">
                                <div class="col-md-3">
                                    <label>Ámbito:</label>
                                    <select name="ambito" class="form-control" onchange="this.form.submit()">
                                        <option value="P" selected="@(esPeru)">PERÚ</option>
                                        <option value="E" selected="@(!esPeru)">EXTRANJERO</option>
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <label>@(esPeru ? "Departamento:" : "Continente:")</label>
                                    <select name="depa" class="form-control" onchange="this.form.submit()">
                                        <option value="">--SELECCIONE--</option>
                                        @foreach (var item in Model.Departamentos ?? new List<UbigeoSelectListItem>())
                                        {
                                            <option value="@item.Value" selected="@(item.Value == Model.DepartamentoSeleccionado)">@item.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <label>@(esPeru ? "Provincia:" : "País:")</label>
                                    <select name="prov" class="form-control" onchange="this.form.submit()">
                                        <option value="">--SELECCIONE--</option>
                                        @foreach (var item in Model.Provincias ?? new List<UbigeoSelectListItem>())
                                        {
                                            <option value="@item.Value" selected="@(item.Value == Model.ProvinciaSeleccionado)">@item.Text</option>
                                        }
                                    </select>
                                </div>

                                
                            </div>

                            <div class="row mt-3">
                                <div class="col-md-4">
                                    <label>@(esPeru ? "Distrito:" : "Ciudad:")</label>
                                    <select name="dist" class="form-control" onchange="this.form.submit()">
                                        <option value="">--SELECCIONE--</option>
                                        @foreach (var item in Model.Distritos ?? new List<UbigeoSelectListItem>())
                                        {
                                            <option value="@item.Value" selected="@(item.Value == Model.DistritoSeleccionado)">@item.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-8">
                                    <label>Locales:</label>
                                    <select name="local" class="form-control" onchange="this.form.submit()">
                                        <option value="">--SELECCIONE--</option>
                                        @foreach (var item in Model.Locales ?? new List<UbigeoSelectListItem>())
                                        {
                                            <option value="@item.Value" selected="@(item.Value == Model.LocalSeleccionado)">@item.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </form>

                        @if (mostrarListadoMesas)
                        {
                            <div id="divDetalle" class="ptop20">
                                <div class="col-xs-12 pbot30">
                                    <p class="subtitle">LISTADO DE MESAS</p>
                                    <div id="page-wrap">
                                        <table class="table17" cellspacing="0">
                                            <tbody>
                                                @{
                                                    var mesas = Model.Mesas ?? new List<UbigeoSelectListItem>();
                                                    int count = 0;
                                                }
                                                @for (int i = 0; i < mesas.Count; i += 10)
                                                {
                                                    <tr>
                                                        @for (int j = 0; j < 10 && (i + j) < mesas.Count; j++)
                                                        {
                                                            var mesa = mesas[i + j];
                                                            var bgColor = mesa.Value == currentMesa ? "#B29445" : "#C1C1C1";
                                                            var url = Url.Action("ActasUbigeo", new { ambito = currentAmbito, depa = currentDepa, prov = currentProv, dist = currentDist, local = currentLocal, mesa = mesa.Value });
                                                            <td bgcolor="@bgColor" onclick="location.href='@url'" style="cursor:pointer;">
                                                                <a href="@url">@mesa.Text</a>
                                                            </td>
                                                        }
                                                        @for (int j = mesas.Count - i; j < 10; j++)
                                                        {
                                                            <td>&nbsp;</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="col-xs-12 cont-recto oculto-leyenda-color-fondo-mesas">
                                    <div class="col-md-4">
                                        <img src="~/images/procesacon.jpg" alt="Procesada con imagen"> Procesada con imagen
                                        </div>
                                        <div class="col-md-4">
                                            <img src="~/images/procesasin.jpg" alt="Procesada sin imagen"> Procesada sin imagen
                                            </div>
                                            <div class="col-md-4">
                                                <img src="~/images/sinprocesa.jpg" alt="Sin procesar"> Sin procesar
                                                </div>
                                            </div>

                                            <div class="row pbot30">
                                                <div class="col-lg-8 centered">
                                                    <div class="col-xs-12 col-md-12 col-lg-12">
                                                        <table>
                                                            <tbody>
                                                                <tr>
                                                                    <td colspan="10">
                                                                        <div class="conte-paginador">
                                                                            <span class="paginador-txt">Total de mesas: @(mesas.Count)</span>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>&nbsp;</td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="10">
                                                                        Página:
                                                                        <ul class="pagination">
                                                                            <li class="active"><a class="paginador-n1">1</a></li>
                                                                        </ul>
                                                                    </td>
                                                                    <br />
                                                                    <br />
                                                                    <br />
                                                                    <br />
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    <br /><br /><br /><br />

                                    @if (mostrarDetalleActa && Model.ActaDetalle != null)
                                    {
                                        <div id="divDetalle" class="ptop20">
                                            <div class="contenido-resultados">
                                                <button class="btn btn-primary pull-right" onclick="history.back()" type="button">
                                                    <span class="glyphicon glyphicon-chevron-left" aria-hidden="true"></span>
                                                    REGRESAR
                                                </button>
                                                <p>&nbsp;</p>

                                                <div class="row">
                                                    <div class="tab-info">
                                                        <div class="tab-content">
                                                            <div id="detMesa">
                                                                <div class="tab-content">
                                                                    <div role="tabpanel" class="tab-pane active" id="presidencial">
                                                                        <div class="tab-info-desc">
                                                                            <div class="row">
                                                                                <div class="col-xs-3 col-md-4">
                                                                                    <div class="mesap01">
                                                                                        <img src="~/images/mp-sin.jpg" class="img-responsive">
                                                                                            Si requiere la imagen del acta, solicítela a través del procedimiento de acceso a la información pública.
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="col-xs-9 col-md-8">
                                                                                        <div class="row">
                                                                                            <div class="col-xs-12">
                                                                                                <p class="subtitle1">ACTA ELECTORAL</p>
                                                                                                <div id="page-wrap">
                                                                                                    <table class="table13" cellspacing="0">
                                                                                                        <thead>
                                                                                                            <tr>
                                                                                                                <th>Mesa N°</th>
                                                                                                                <th>N° Copia</th>
                                                                                                            </tr>
                                                                                                        </thead>
                                                                                                        <tbody>
                                                                                                            <tr>
                                                                                                                <td>@(Model.ActaDetalle.MesaNro ?? "—")</td>
                                                                                                                <td>@(Model.ActaDetalle.Copia ?? "—")</td>
                                                                                                            </tr>
                                                                                                        </tbody>
                                                                                                    </table>
                                                                                                </div>
                                                                                            </div>

                                                                                            <div class="col-xs-12">
                                                                                                <p class="subtitle1">INFORMACIÓN UBIGEO</p>
                                                                                                <div id="page-wrap">
                                                                                                    <table class="table14" cellspacing="0">
                                                                                                        <tbody>
                                                                                                            <tr class="titulo_tabla">
                                                                                                                <td>Departamento</td>
                                                                                                                <td>Provincia</td>
                                                                                                                <td>Distrito</td>
                                                                                                                <td>Local de votación</td>
                                                                                                                <td>Dirección</td>
                                                                                                            </tr>
                                                                                                            <tr>
                                                                                                                <td>@(Model.ActaDetalle.Departamento ?? "—")</td>
                                                                                                                <td>@(Model.ActaDetalle.Provincia ?? "—")</td>
                                                                                                                <td>@(Model.ActaDetalle.Distrito ?? "—")</td>
                                                                                                                <td>@(Model.ActaDetalle.LocalVotacion ?? "—")</td>
                                                                                                                <td>@(Model.ActaDetalle.Direccion ?? "—")</td>
                                                                                                            </tr>
                                                                                                        </tbody>
                                                                                                    </table>
                                                                                                </div>
                                                                                            </div>

                                                                                            <div class="col-xs-12">
                                                                                                <p class="subtitle1">INFORMACIÓN MESA</p>
                                                                                                <div id="page-wrap">
                                                                                                    <table class="table15" cellspacing="0">
                                                                                                        <tbody>
                                                                                                            <tr class="titulo_tabla">
                                                                                                                <td>Electores hábiles</td>
                                                                                                                <td>Total votantes</td>
                                                                                                                <td>Estado del acta</td>
                                                                                                            </tr>
                                                                                                            <tr>
                                                                                                                <td>@Model.ActaDetalle.ElectoresHabiles</td>
                                                                                                                <td>@Model.ActaDetalle.TotalVotantes</td>
                                                                                                                <td>@Model.ActaDetalle.EstadoActa</td>
                                                                                                            </tr>
                                                                                                        </tbody>
                                                                                                    </table>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>

                                                                                <div>
                                                                                    <div class="col-xs-12 pbot30_acta">
                                                                                        <p class="subtitle1">LISTA DE RESOLUCIONES</p>
                                                                                        <span class="glyphicon glyphicon-info-sign" aria-hidden="true"></span> No hay resoluciones para el acta seleccionada
                                                                                        <div id="page-wrap">
                                                                                            <div class="col-md-12 resolu"></div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>

                                                                                <div>
                                                                                    <div class="col-xs-12">
                                                                                        <p class="subtitle1">INFORMACIÓN DEL ACTA ELECTORAL</p>
                                                                                        <div id="page-wrap" class="cont-tabla1">
                                                                                            <table class="table06">
                                                                                                <tbody>
                                                                                                    <tr class="titulo_tabla">
                                                                                                        <td colspan="2">Organización política</td>
                                                                                                        <td>Total de Votos</td>
                                                                                                    </tr>
                                                                                                    <tr>
                                                                                                        <td>PERUANOS POR EL KAMBIO</td>
                                                                                                        <td><img width="40px" height="40px" src="~/images/simbolo_pkk.jpg"></td>
                                                                                                        <td>@Model.ActaDetalle.P1</td>
                                                                                                    </tr>
                                                                                                    <tr>
                                                                                                        <td>FUERZA POPULAR</td>
                                                                                                        <td><img width="40px" height="40px" src="~/images/simbolo_keyko.jpg"></td>
                                                                                                        <td>@Model.ActaDetalle.P2</td>
                                                                                                    </tr>
                                                                                                    <tr>
                                                                                                        <td colspan="2">VOTOS EN BLANCO</td>
                                                                                                        <td>@Model.ActaDetalle.Blancos</td>
                                                                                                    </tr>
                                                                                                    <tr>
                                                                                                        <td colspan="2">VOTOS NULOS</td>
                                                                                                        <td>@Model.ActaDetalle.Nulos</td>
                                                                                                    </tr>
                                                                                                    <tr>
                                                                                                        <td colspan="2">VOTOS IMPUGNADOS</td>
                                                                                                        <td>@Model.ActaDetalle.Impugnados</td>
                                                                                                    </tr>
                                                                                                    <tr>
                                                                                                        <td colspan="2">TOTAL DE VOTOS EMITIDOS</td>
                                                                                                        <td>@Model.ActaDetalle.TotalVotantes</td>
                                                                                                    </tr>
                                                                                                </tbody>
                                                                                            </table>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }